<a class="border rounded-lg flex items-center gap-4 shadow-[0_2px_15px_-3px_rgba(0,0,0,0.07),0_10px_20px_-2px_rgba(0,0,0,0.04)] dark:bg-neutral-700" href="<%= @resource.relative_url %>">
  <img class="w-24 h-36 md:w-36 md:h-48 object-cover rounded-s-lg" src="<%= @resource.data.img %>" alt="<%= @resource.data.titolo %>" />

  <div class="grid gap-4"">
    <h3 class="font-bold"><%= @resource.data.titolo %></h3>
    <div class="flex space-x-2">
      <%= render DateBadge.new(date: date) %>
    </div>
    <div class="flex space-x-2">
      <%- @resource.data.orari.each do |time| %>
        <%= render TimeBadge.new(time: time) %>
      <% end %>
    </div>
    <%- if @resource.data.note %>
      <p class="font-small font-serif font-light"><%= @resource.data.note %></p>
    <% end %>
  </div>
</a>
